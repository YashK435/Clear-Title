# ClearTitle IPFS Proxy — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Required ──────────────────────────────────────────────────
# Your Pinata API JWT — get from https://app.pinata.cloud/keys
PINATA_JWT=your_pinata_jwt_here

# ── Optional ──────────────────────────────────────────────────
# Port to run the proxy on (default: 3001)
PORT=3001

# Allowed frontend origin for CORS (use * for development, set your domain in production)
# Examples:
#   ALLOWED_ORIGIN=http://localhost:5500
#   ALLOWED_ORIGIN=https://cleartitle.yourdomain.com
ALLOWED_ORIGIN=*
